# K9LogBot Environment Configuration

# Required - Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
YOUR_TELEGRAM_CHAT_ID=your_chat_id_here

# Performance Optimization Settings for Raspberry Pi

# OLED display update interval (seconds)
# Higher values = less CPU usage, lower display refresh rate
# Recommended: 10-15 for Raspberry Pi Zero/1, 5-10 for Pi 3/4
DISPLAY_UPDATE_INTERVAL=10

# Statistics cache duration (seconds)
# Higher values = fewer database queries, slightly staler data
# Recommended: 30-60 seconds
STATS_CACHE_DURATION=30

# Automatic Database Cleanup Settings
# Automatically removes old transaction records to keep database clean
# Runs on the specified day of each month at 03:00 AM

# Day of month to run cleanup (1-28, recommended: 10)
# Example: 10 = cleanup runs on the 10th of every month
AUTO_CLEANUP_DAY=10

# Number of months of records to keep (default: 1)
# 1 = keep only current month records
# 2 = keep current + previous month records
# 3 = keep current + 2 previous months records
AUTO_CLEANUP_MONTHS_TO_KEEP=1

# Enable/disable automatic cleanup (true/false)
AUTO_CLEANUP_ENABLED=true

# Database settings are automatically optimized for performance
# No configuration needed for SQLite optimizations